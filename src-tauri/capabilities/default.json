{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for the local Markdown editor.",
  "windows": [
    "main",
    "mmd-editor-popout",
    "mmd-preview-popout"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-destroy",
    "core:window:allow-set-focus"
  ]
}
