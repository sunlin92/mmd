{
  "name": "mmd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm run sync:vendor-assets",
    "prebuild": "npm run sync:vendor-assets",
    "predev": "npm run sync:vendor-assets",
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint --deny-warnings --react-plugin --jsx-a11y-plugin --vitest-plugin",
    "check:release-version": "node scripts/check-release-version.mjs",
    "test:release-version": "node --test scripts/check-release-version.test.mjs",
    "test:release-tools": "node --test scripts/check-release-version.test.mjs scripts/release-workflow.node-test.mjs scripts/ci/artifact-manifest.test.mjs scripts/ci/smoke-linux.node-test.mjs scripts/ci/smoke-macos.node-test.mjs",
    "sync:pdf-assets": "node scripts/sync-pdf-assets.mjs",
    "sync:third-party-notices": "node scripts/sync-third-party-notices.mjs",
    "sync:vendor-assets": "npm run sync:pdf-assets && npm run sync:third-party-notices"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.4",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/language": "6.12.4",
    "@codemirror/search": "6.7.1",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@excalidraw/excalidraw": "0.18.1",
    "@lezer/highlight": "1.2.3",
    "@replit/codemirror-vim": "6.3.0",
    "@tauri-apps/api": "2.11.1",
    "dompurify": "3.4.12",
    "katex": "0.17.0",
    "lucide-react": "1.23.0",
    "mammoth": "1.12.0",
    "mermaid": "11.16.0",
    "mpegts.js": "1.8.0",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "rehype-katex": "7.0.1",
    "remark-breaks": "4.0.0",
    "remark-cjk-friendly": "2.3.1",
    "remark-gfm": "4.0.1",
    "remark-github-alerts": "0.1.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.3",
    "jsdom": "29.1.1",
    "oxlint": "1.73.0",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
